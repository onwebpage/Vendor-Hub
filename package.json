{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "packageManager": "pnpm@10.26.1",
  "engines": {
    "node": ">=22.x"
  },
  "scripts": {
    "predev": "fuser -k 5000/tcp || exit 0",
    "dev": "pnpm --filter @workspace/api-server run dev",
    "build": "pnpm -r --if-present run build",
    "build:render": "pnpm --filter @workspace/vendorkart run build && pnpm --filter @workspace/api-server run build",
    "start:render": "node ./artifacts/api-server/dist/index.mjs",
    "typecheck": "tsc --build && pnpm -r --filter \"./artifacts/**\" --if-present run typecheck",
    "start": "pnpm --filter @workspace/api-server start"
  },
  "private": true,
  "devDependencies": {
    "kill-port": "^2.0.1",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2"
  }
}
